# Public entry for www.bvshen.com — the TradingAgents web UI is mounted at
# /trading-agents/ rather than the apex, so the rest of the domain stays
# free for other things.
#
# Cloudflare is in front of us as a reverse proxy. We support two
# configurations on this origin:
#
#   1. CF proxy on (orange cloud) AND anyone reaching the origin directly
#      over the public IP — caddy serves a public Let's Encrypt cert so
#      both paths show 🔒 in the browser.
#
#   2. CF proxy off (gray cloud) — same LE cert handles direct traffic;
#      CF just acts as authoritative DNS.
#
# We do NOT also use a Cloudflare Origin cert anymore. The previous setup
# had a CF Origin cert on caddy and the public on CF's edge, which meant
# that anyone bypassing CF (gray-cloud moment, an old DNS cache, a
# laptop pointed at the VPS IP, etc.) got the untrusted Origin cert and
# Chrome showed "Not Secure". Serving the same public LE cert on both
# paths makes the site work the same way regardless of how the client
# reached us.

# ----- Global options -----

{
    email admin@bvshen.com
}

# ----- Site block -----

www.bvshen.com, bvshen.com {
    encode gzip

    # Bind to all interfaces on 80 and 443. Port 80 is still useful so
    # Cloudflare can do HTTP→HTTPS upgrades and so any leftover LE
    # validation works.
    log {
        output stdout
        level INFO
    }

    # Visiting the bare hostname or / gets redirected to /trading-agents/.
    @root {
        path / /
    }
    handle @root {
        redir https://{host}/trading-agents/ 302
    }

    # The actual app. Strip the /trading-agents prefix before proxying, so
    # FastAPI continues to see its app at "/" and the prefix is invisible
    # to the backend. The web service listens on host port 8000 — whether
    # that's a docker-compose container published at 8000:8000, a
    # systemd-managed uvicorn, or a manually launched process, the
    # Caddyfile stays the same.
    handle /trading-agents/* {
        uri strip_prefix /trading-agents
        reverse_proxy 127.0.0.1:8000 {
            # Trust the CF-Connecting-IP header so FastAPI sees the real
            # client IP, not Cloudflare's edge IP. Caddy already knows
            # Cloudflare's IP ranges (the `cloudflare` shorthand is built
            # in) and will honor CF-Connecting-IP from those ranges only.
            header_up X-Forwarded-For "{http.request.header.CF-Connecting-IP}"
            header_up X-Real-IP "{http.request.header.CF-Connecting-IP}"
            # Also pass through CF-IPCountry so the device whitelist can
            # record (and display) the country the user is logging in
            # from. Same trust boundary as X-Forwarded-For — FastAPI only
            # honors it when the immediate peer is in its trusted-proxy
            # set.
            header_up CF-IPCountry "{http.request.header.CF-IPCountry}"
        }
    }

    # Anything else → 404. The path-prefix app is the only thing we expose.
    handle {
        respond "Not Found" 404
    }

    # No `tls` directive — caddy auto-issues a public Let's Encrypt cert
    # for `www.bvshen.com` and `bvshen.com` via the HTTP-01 challenge on
    # port 80. The cert is renewed automatically before expiry.
}
